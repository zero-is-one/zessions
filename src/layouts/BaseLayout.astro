---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zessions | NYC Irish Sessions',
  description = 'Find Irish sessions happening around New York City.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main>
      <header class="mb-8 animate-rise">
        <div class="glass p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-harbor">New York Irish Music</p>
          <h1 class="mt-3 font-display text-4xl leading-tight text-peat sm:text-5xl">Zessions</h1>
          <p class="mt-3 max-w-3xl text-base text-peat/80 sm:text-lg">
            Track sessions across NYC with date-aware recurrence, map locations, and quick alerts.
          </p>
        </div>
      </header>
      <slot />
    </main>
  </body>
</html>
