---
import '../styles/global.css';
import { CITY_NAME } from '../lib/city';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `Find A Session * ${CITY_NAME}`,
  description = `Find Irish sessions happening around ${CITY_NAME}.`,
} = Astro.props;

const isHome = true;
const mainClass = isHome
  ? 'mx-auto flex h-dvh w-full flex-col overflow-hidden p-3 sm:p-4 lg:px-5'
  : 'mx-auto w-full max-w-6xl px-4 pb-14 pt-8 sm:px-6 lg:px-8';
const bodyClass = isHome ? 'overflow-hidden' : '';
const headerWrapClass = isHome ? 'mb-3 animate-rise' : 'mb-8 animate-rise';
const headerCardClass = isHome ? 'glass p-4 sm:p-5' : 'glass p-6 sm:p-8';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={bodyClass}>
    <main class={mainClass}>
      <slot />
    </main>
  </body>
</html>
