---
import { getCollection } from 'astro:content';
import { addMonths } from 'date-fns';
import SessionsTabs from '../components/SessionsTabs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { expandSessionOccurrences } from '../lib/sessions';

const sessions = (await getCollection('sessions')).filter((session: any) => !session.data.draft);
const windowStart = new Date();
const windowEnd = addMonths(windowStart, 6);
const occurrences = expandSessionOccurrences(sessions, windowStart, windowEnd).map((item) => ({
  ...item,
  start: item.start.toISOString(),
  end: item.end?.toISOString(),
}));
---

<BaseLayout title="Zessions | NYC Irish Sessions" description="Browse Irish sessions happening around New York.">
  <SessionsTabs client:only="react" occurrences={occurrences} />
</BaseLayout>
