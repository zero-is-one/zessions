---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailMap from '../../components/DetailMap';

export async function getStaticPaths() {
  const sessions = (await getCollection('sessions')).filter((session: any) => !session.data.draft);

  return sessions.map((session: any) => ({
    params: { slug: session.id },
    props: { session },
  }));
}

const { session } = Astro.props as { session: any };
const { Content } = await render(session);

function recurrenceSummary(): string {
  const data = session.data;
  if (data.recurrenceType === 'single') {
    return 'Single-date session.';
  }
  if (data.recurrenceType === 'date-list') {
    return `Specific dates (${data.occurrenceDates.length} listed).`;
  }
  return `Repeating schedule via RRULE: ${data.recurrenceRule ?? 'not set'}`;
}
---

<BaseLayout title={`${session.data.title} | Zessions`} description={session.data.description ?? 'Irish session details'}>
  <article class="glass p-6 sm:p-8">
    <a class="text-sm font-semibold text-harbor hover:underline" href="/">← Back to sessions</a>
    <h2 class="mt-3 font-display text-4xl text-peat">{session.data.title}</h2>
    <p class="mt-2 text-sm text-peat/70">{session.data.locationName}</p>

    <dl class="mt-6 grid gap-3 text-sm text-peat/85 sm:grid-cols-2">
      <div>
        <dt class="font-semibold">Address</dt>
        <dd>{session.data.address}</dd>
      </div>
      <div>
        <dt class="font-semibold">Timezone</dt>
        <dd>{session.data.timezone}</dd>
      </div>
      <div>
        <dt class="font-semibold">General info</dt>
        <dd>{session.data.generalInfo}</dd>
      </div>
      <div class="sm:col-span-2">
        <dt class="font-semibold">Recurrence</dt>
        <dd>{recurrenceSummary()}</dd>
      </div>
      {session.data.alerts && session.data.alerts !== 'No alerts.' && (
        <div class="sm:col-span-2">
          <div class="flex items-start gap-2 rounded-lg bg-red-600 px-4 py-3 text-sm font-medium text-white">
            <span class="mt-px shrink-0 text-base leading-none" aria-hidden="true">&#9888;</span>
            <span>{session.data.alerts}</span>
          </div>
        </div>
      )}
    </dl>

    <div class="prose prose-neutral mt-6 max-w-none prose-headings:font-display">
      <Content />
    </div>

    {session.data.latitude && session.data.longitude && (
      <div class="mt-8">
        <div class="mb-3 flex items-center justify-between">
          <h3 class="font-display text-xl text-peat">Location</h3>
          <a
            class="flex items-center gap-1.5 rounded-full bg-harbor px-4 py-1.5 text-sm font-semibold text-white hover:bg-harbor/90"
            href={`https://www.google.com/maps/dir/?api=1&destination=${session.data.latitude},${session.data.longitude}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="3 11 22 2 13 21 11 13 3 11"/>
            </svg>
            Get directions
          </a>
        </div>
        <DetailMap
          client:only="react"
          lat={session.data.latitude}
          lng={session.data.longitude}
          title={session.data.title}
          locationName={session.data.locationName}
        />
      </div>
    )}
  </article>
</BaseLayout>
