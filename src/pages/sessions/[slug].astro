---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailMap from '../../components/DetailMap';
import { CITY_NAME } from '../../lib/city';

export async function getStaticPaths() {
  const sessions = (await getCollection('sessions')).filter((session: any) => !session.data.draft);

  return sessions.map((session: any) => ({
    params: { slug: session.id },
    props: { session },
  }));
}

const { session } = Astro.props as { session: any };
const { Content } = await render(session);
const displayTitle = session.data.title ?? session.data.locationName;

function formatTime(t: string): string {
  const [hStr, mStr] = t.split(':');
  let h = parseInt(hStr, 10);
  const m = parseInt(mStr, 10);
  const ampm = h < 12 || h === 0 ? 'am' : 'pm';
  if (h === 0) h = 12;
  else if (h > 12) h -= 12;
  return m === 0 ? `${h}${ampm}` : `${h}:${mStr}${ampm}`;
}

const timeLabel = formatTime(session.data.startTime) +
  (session.data.endTime ? ` – ${formatTime(session.data.endTime)}` : '');
---

<BaseLayout title={`${displayTitle} | Find A Session ${CITY_NAME}`} description={session.data.description ?? 'Irish session details'}>
  <article class="glass p-6 sm:p-8">
    <a class="text-sm font-semibold text-harbor hover:underline" href="/">← Back to sessions</a>
    <h2 class="mt-3 font-display text-4xl text-peat">{displayTitle}</h2>
    <p class="mt-2 text-sm text-peat/70">{session.data.locationName}</p>

    <dl class="mt-6 grid gap-3 text-sm text-peat/85 sm:grid-cols-2">
      <div>
        <dt class="font-semibold">Address</dt>
        <dd>{session.data.address}</dd>
      </div>
      <div>
        <dt class="font-semibold">Time</dt>
        <dd>{timeLabel}</dd>
      </div>
      <div>
        <dt class="font-semibold">General info</dt>
        <dd>{session.data.generalInfo}</dd>
      </div>
      <div>
        <dt class="font-semibold">Schedule</dt>
        <dd>{session.data.schedule.charAt(0).toUpperCase() + session.data.schedule.slice(1)}</dd>
      </div>
      {session.data.alerts && session.data.alerts !== 'No alerts.' && (
        <div class="sm:col-span-2">
          <div class="flex items-start gap-2 bg-red-600 px-4 py-3 text-sm font-medium text-white">
            <span class="mt-px shrink-0 text-base leading-none" aria-hidden="true">&#9888;</span>
            <span>{session.data.alerts}</span>
          </div>
        </div>
      )}
    </dl>

    <div class="prose prose-neutral mt-6 max-w-none prose-headings:font-display">
      <Content />
    </div>

    {session.data.address && (
      <div class="mt-8">
        <div class="mb-3 flex items-center justify-between">
          <h3 class="font-display text-xl text-peat">Location</h3>
          <a
            class="flex items-center gap-1.5 bg-harbor px-4 py-1.5 text-sm font-semibold text-white hover:bg-harbor/90"
            href={session.data.googleMapsLink || `https://www.google.com/maps/search/${encodeURIComponent(session.data.address)}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="3 11 22 2 13 21 11 13 3 11"/>
            </svg>
            Get directions
          </a>
        </div>
        <DetailMap
          client:only="react"
          lat={session.data.latitude}
          lng={session.data.longitude}
          title={displayTitle}
          locationName={session.data.locationName}
        />
      </div>
    )}
  </article>
</BaseLayout>
